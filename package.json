{
	"name": "casadeguara",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "npm run db:start && npm run services:wait:database && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "npm run db:start && concurrently -n vite,vitest --hide vite -k -s command-vitest \"npm run dev\" \"vitest -- --run\"",
		"posttest": "docker compose down --volumes",
		"services:wait:database": "node src/lib/scripts/wait-for-postgres.js",
		"db:start": "docker compose up -d",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/async-retry": "^1.4.9",
		"@types/eslint": "^9.6.1",
		"@types/validator": "^13.15.10",
		"bulma": "^1.0.4",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"lucia": "^3.2.2",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"sass": "^1.101.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fortawesome/fontawesome-free": "^7.2.0",
		"@lucia-auth/adapter-drizzle": "^1.1.0",
		"@types/qrcode": "^1.5.6",
		"argon2": "^0.44.0",
		"async-retry": "^1.3.3",
		"dayjs": "^1.11.21",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"extenso": "^2.1.0",
		"postgres": "^3.4.9",
		"qrcode": "^1.5.4",
		"uuid": "^14.0.0",
		"validator": "^13.15.35",
		"vercel": "^54.14.2",
		"zod": "^4.4.3"
	}
}
